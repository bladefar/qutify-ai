# Supabase — copy to .env.local (from Project Settings → API)

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Backend-only Supabase secret key used for verified billing-state writes.
# A legacy service-role key is also supported as SUPABASE_SERVICE_ROLE_KEY.
SUPABASE_SECRET_KEY=

# Legacy anon key also works if your project still uses it:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# OpenRouter — keep this server-only; never prefix it with NEXT_PUBLIC_
OPENROUTER_API_KEY=your-openrouter-api-key
# Optional: defaults to openai/gpt-4o-mini
# OPENROUTER_MODEL=openai/gpt-4o-mini

# Razorpay Subscriptions — Test Mode only. Keep all values except the Key ID
# server-only; the app returns the public Test Key ID from a protected action.
RAZORPAY_MODE=test
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_PRO_MONTHLY_PLAN_ID=
RAZORPAY_PRO_ANNUAL_PLAN_ID=

# Public origin used for server-generated billing redirects/callbacks.
APP_URL=http://127.0.0.1:3000
