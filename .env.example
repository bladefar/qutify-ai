# Supabase — copy to .env.local (from Project Settings → API)

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Legacy anon key also works if your project still uses it:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# OpenRouter — keep this server-only; never prefix it with NEXT_PUBLIC_
OPENROUTER_API_KEY=your-openrouter-api-key
# Optional: defaults to openai/gpt-4o-mini
# OPENROUTER_MODEL=openai/gpt-4o-mini
